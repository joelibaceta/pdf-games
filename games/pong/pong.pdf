if (typeof _pdfgame_loaded === 'undefined') {
var _pdfgame_loaded = true;
/* PDF Game Engine - Acrobat JS (ES3) */
var _doc = this; // captured at script top level - in Acrobat doc context this IS the document

var Engine = (function () {
    var _intervalId = null;
    var PAGE_H = 200;

    function _pdfRect(gx, gy, w, h) {
        var py = PAGE_H - gy - h;
        return [gx, py, gx + w, py + h];
    }

    function _gamePos(f) {
        var r = f.rect;
        var w = r[2] - r[0];
        var h = r[3] - r[1];
        return { x: r[0], y: PAGE_H - r[3], w: w, h: h };
    }

    return {
        _updateFn: null,
        _sprites: {"net": 1, "paddle_p": 1, "paddle_cpu": 1, "ball": 1},
        _sizes: {"net": {w: 2, h: 200}, "paddle_p": {w: 8, h: 50}, "paddle_cpu": {w: 8, h: 50}, "ball": {w: 10, h: 10}},
        _pos: {},     /* position registry: {name: {x,y,w,h}} in game coords */

        start: function (updateFn, fps) {
            if (_intervalId !== null) { return; } /* guard: only one interval */
            Engine._updateFn = updateFn;
            _intervalId = app.setInterval(
                "Engine._tick()", Math.round(1000 / fps)
            );
        },

        stop: function () {
            if (_intervalId !== null) {
                app.clearInterval(_intervalId);
                _intervalId = null;
            }
        },

        _tick: function () {
            if (Engine._updateFn) { Engine._updateFn(); }
        },

        _field: function (name) {
            var nf = Engine._sprites[name] || 1;
            var fname = nf > 1 ? "sprite_" + name + "_0" : "sprite_" + name;
            return _doc.getField(fname);
        },

        move: function (name, gx, gy) {
            var nf = Engine._sprites[name] || 1;
            var sz = Engine._sizes[name] || { w: 0, h: 0 };
            var posW = sz.w, posH = sz.h;
            for (var fi = 0; fi < nf; fi++) {
                var fname = nf > 1 ? "sprite_" + name + "_" + fi : "sprite_" + name;
                var f = _doc.getField(fname);
                if (!f) { continue; }
                f.rect = _pdfRect(gx, gy, posW, posH);
            }
            Engine._pos[name] = { x: gx, y: gy, w: posW, h: posH };
        },

        getPos: function (name) {
            if (Engine._pos[name]) { return Engine._pos[name]; }
            var f = Engine._field(name);
            if (!f) { return { x: 0, y: 0, w: 0, h: 0 }; }
            return _gamePos(f);
        },

        show: function (name) {
            var f = _doc.getField("sprite_" + name);
            if (f) { f.display = display.visible; }
        },

        hide: function (name) {
            var f = _doc.getField("sprite_" + name);
            if (f) { f.display = display.hidden; }
        },

        setText: function (name, val) {
            var f = _doc.getField("text_" + name);
            if (f) { f.value = "" + val; }
        },

        collides: function (a, b) {
            var pa = Engine.getPos(a);
            var pb = Engine.getPos(b);
            return !(
                pa.x + pa.w <= pb.x || pb.x + pb.w <= pa.x ||
                pa.y + pa.h <= pb.y || pb.y + pb.h <= pa.y
            );
        },

        random: function (min, max) {
            return Math.floor(Math.random() * (max - min + 1)) + min;
        },

        onInput: function (cb) { Engine._inputCb = cb; },

        triggerInput: function () {
            if (Engine._inputCb) { Engine._inputCb(); }
        },

        _inputCb: null
    };
})();

(function() { for (var sn in Engine._sprites) { var nf = Engine._sprites[sn]; for (var fi = 1; fi < nf; fi++) { var f = _doc.getField('sprite_' + sn + '_' + fi); if (f) { f.display = display.hidden; } } } })();
var _net_x = 249;
var _net_y = 0;
var _paddle_p_x = 15;
var _paddle_p_y = 75;
var _paddle_cpu_x = 477;
var _paddle_cpu_y = 75;
var _ball_x = 245;
var _ball_y = 95;
var bvx = 7;
var bvy = 4;
var pdir = 1;
var sp = 0;
var sc = 0;
var alive = true;

function _on_update() {
    if ((!alive)) {
        return;
    }
    _paddle_p_y = (_paddle_p_y + (pdir * 5));
    Engine.move("paddle_p", _paddle_p_x, _paddle_p_y);
    if ((_paddle_p_y <= 0)) {
        _paddle_p_y = 0;
        Engine.move("paddle_p", _paddle_p_x, _paddle_p_y);
        pdir = 1;
    }
    if ((_paddle_p_y >= 150)) {
        _paddle_p_y = 150;
        Engine.move("paddle_p", _paddle_p_x, _paddle_p_y);
        pdir = -1;
    }
    if (((_paddle_cpu_y + 25) < _ball_y)) {
        _paddle_cpu_y = (_paddle_cpu_y + 3);
        Engine.move("paddle_cpu", _paddle_cpu_x, _paddle_cpu_y);
    }
    if (((_paddle_cpu_y + 25) > _ball_y)) {
        _paddle_cpu_y = (_paddle_cpu_y - 3);
        Engine.move("paddle_cpu", _paddle_cpu_x, _paddle_cpu_y);
    }
    if ((_paddle_cpu_y < 0)) {
        _paddle_cpu_y = 0;
        Engine.move("paddle_cpu", _paddle_cpu_x, _paddle_cpu_y);
    }
    if ((_paddle_cpu_y > 150)) {
        _paddle_cpu_y = 150;
        Engine.move("paddle_cpu", _paddle_cpu_x, _paddle_cpu_y);
    }
    _ball_x = (_ball_x + bvx);
    Engine.move("ball", _ball_x, _ball_y);
    _ball_y = (_ball_y + bvy);
    Engine.move("ball", _ball_x, _ball_y);
    if ((_ball_y <= 0)) {
        _ball_y = 0;
        Engine.move("ball", _ball_x, _ball_y);
        if ((bvy < 0)) {
            bvy = (-bvy);
        }
    }
    if ((_ball_y >= 190)) {
        _ball_y = 190;
        Engine.move("ball", _ball_x, _ball_y);
        if ((bvy > 0)) {
            bvy = (-bvy);
        }
    }
    if (((((_ball_x <= 24) && (_ball_x >= 10)) && ((_ball_y + 10) >= _paddle_p_y)) && (_ball_y <= (_paddle_p_y + 50)))) {
        if ((bvx < 0)) {
            bvx = (-bvx);
        }
    }
    if ((((((_ball_x + 10) >= 477) && (_ball_x <= 482)) && ((_ball_y + 10) >= _paddle_cpu_y)) && (_ball_y <= (_paddle_cpu_y + 50)))) {
        if ((bvx > 0)) {
            bvx = (-bvx);
        }
    }
    if ((_ball_x < 0)) {
        sc = (sc + 1);
        Engine.setText("score_c", sc);
        _ball_x = 245;
        Engine.move("ball", _ball_x, _ball_y);
        _ball_y = 95;
        Engine.move("ball", _ball_x, _ball_y);
        bvx = 7;
        bvy = 4;
        if ((sc >= 5)) {
            alive = false;
            Engine.setText("msg", "CPU wins! Click to restart");
        }
    }
    if ((_ball_x > 490)) {
        sp = (sp + 1);
        Engine.setText("score_p", sp);
        _ball_x = 245;
        Engine.move("ball", _ball_x, _ball_y);
        _ball_y = 95;
        Engine.move("ball", _ball_x, _ball_y);
        bvx = -7;
        bvy = 4;
        if ((sp >= 5)) {
            alive = false;
            Engine.setText("msg", "You win! Click to restart");
        }
    }
}

function _on_click() {
    if ((!alive)) {
        _on_restart();
        return;
    }
    pdir = (-pdir);
}

function _on_restart() {
    sp = 0;
    sc = 0;
    alive = true;
    bvx = 7;
    bvy = 4;
    pdir = 1;
    _ball_x = 245;
    Engine.move("ball", _ball_x, _ball_y);
    _ball_y = 95;
    Engine.move("ball", _ball_x, _ball_y);
    _paddle_p_y = 75;
    Engine.move("paddle_p", _paddle_p_x, _paddle_p_y);
    _paddle_cpu_y = 75;
    Engine.move("paddle_cpu", _paddle_cpu_x, _paddle_cpu_y);
    Engine.setText("score_p", sp);
    Engine.setText("score_c", sc);
    Engine.setText("msg", "");
}

Engine.onInput(function () {
    if (typeof _on_click === 'function') { _on_click(); }
});

Engine.start(_on_update, 15);
}
endstream
endobj
