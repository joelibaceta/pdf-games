if (typeof _pdfgame_loaded === 'undefined') {
var _pdfgame_loaded = true;
/* PDF Game Engine - Acrobat JS (ES3) */
var _doc = this; // captured at script top level - in Acrobat doc context this IS the document

var Engine = (function () {
    var _intervalId = null;
    var PAGE_H = 200;

    function _pdfRect(gx, gy, w, h) {
        var py = PAGE_H - gy - h;
        return [gx, py, gx + w, py + h];
    }

    function _gamePos(f) {
        var r = f.rect;
        var w = r[2] - r[0];
        var h = r[3] - r[1];
        return { x: r[0], y: PAGE_H - r[3], w: w, h: h };
    }

    return {
        _updateFn: null,
        _sprites: {"pipe_top_1": 1, "pipe_bot_1": 1, "pipe_top_2": 1, "pipe_bot_2": 1, "bird": 1, "ground": 1},
        _sizes: {"pipe_top_1": {w: 40, h: 170}, "pipe_bot_1": {w: 40, h: 150}, "pipe_top_2": {w: 40, h: 170}, "pipe_bot_2": {w: 40, h: 150}, "bird": {w: 24, h: 24}, "ground": {w: 500, h: 10}},
        _pos: {},     /* position registry: {name: {x,y,w,h}} in game coords */

        start: function (updateFn, fps) {
            if (_intervalId !== null) { return; } /* guard: only one interval */
            Engine._updateFn = updateFn;
            _intervalId = app.setInterval(
                "Engine._tick()", Math.round(1000 / fps)
            );
        },

        stop: function () {
            if (_intervalId !== null) {
                app.clearInterval(_intervalId);
                _intervalId = null;
            }
        },

        _tick: function () {
            if (Engine._updateFn) { Engine._updateFn(); }
        },

        _field: function (name) {
            var nf = Engine._sprites[name] || 1;
            var fname = nf > 1 ? "sprite_" + name + "_0" : "sprite_" + name;
            return _doc.getField(fname);
        },

        move: function (name, gx, gy) {
            var nf = Engine._sprites[name] || 1;
            var sz = Engine._sizes[name] || { w: 0, h: 0 };
            var posW = sz.w, posH = sz.h;
            for (var fi = 0; fi < nf; fi++) {
                var fname = nf > 1 ? "sprite_" + name + "_" + fi : "sprite_" + name;
                var f = _doc.getField(fname);
                if (!f) { continue; }
                f.rect = _pdfRect(gx, gy, posW, posH);
            }
            Engine._pos[name] = { x: gx, y: gy, w: posW, h: posH };
        },

        getPos: function (name) {
            if (Engine._pos[name]) { return Engine._pos[name]; }
            var f = Engine._field(name);
            if (!f) { return { x: 0, y: 0, w: 0, h: 0 }; }
            return _gamePos(f);
        },

        show: function (name) {
            var f = _doc.getField("sprite_" + name);
            if (f) { f.display = display.visible; }
        },

        hide: function (name) {
            var f = _doc.getField("sprite_" + name);
            if (f) { f.display = display.hidden; }
        },

        setText: function (name, val) {
            var f = _doc.getField("text_" + name);
            if (f) { f.value = "" + val; }
        },

        collides: function (a, b) {
            var pa = Engine.getPos(a);
            var pb = Engine.getPos(b);
            return !(
                pa.x + pa.w <= pb.x || pb.x + pb.w <= pa.x ||
                pa.y + pa.h <= pb.y || pb.y + pb.h <= pa.y
            );
        },

        random: function (min, max) {
            return Math.floor(Math.random() * (max - min + 1)) + min;
        },

        onInput: function (cb) { Engine._inputCb = cb; },

        triggerInput: function () {
            if (Engine._inputCb) { Engine._inputCb(); }
        },

        _inputCb: null
    };
})();

(function() { for (var sn in Engine._sprites) { var nf = Engine._sprites[sn]; for (var fi = 1; fi < nf; fi++) { var f = _doc.getField('sprite_' + sn + '_' + fi); if (f) { f.display = display.hidden; } } } })();
var _pipe_top_1_x = 450;
var _pipe_top_1_y = -150;
var _pipe_bot_1_x = 450;
var _pipe_bot_1_y = 130;
var _pipe_top_2_x = 725;
var _pipe_top_2_y = -150;
var _pipe_bot_2_x = 725;
var _pipe_bot_2_y = 130;
var _bird_x = 80;
var _bird_y = 85;
var _ground_x = 0;
var _ground_y = 190;
var vy = 0;
var alive = true;
var points = 0;
var pipe_x1 = 450;
var pipe_x2 = 725;
var gap_top1 = 80;
var gap_top2 = 55;
var gap_sz1 = 80;
var gap_sz2 = 80;
var scored1 = false;
var scored2 = false;

function _on_start() {
    _pipe_top_1_y = (gap_top1 - 170);
    Engine.move("pipe_top_1", _pipe_top_1_x, _pipe_top_1_y);
    _pipe_bot_1_y = (gap_top1 + gap_sz1);
    Engine.move("pipe_bot_1", _pipe_bot_1_x, _pipe_bot_1_y);
    _pipe_top_2_y = (gap_top2 - 170);
    Engine.move("pipe_top_2", _pipe_top_2_x, _pipe_top_2_y);
    _pipe_bot_2_y = (gap_top2 + gap_sz2);
    Engine.move("pipe_bot_2", _pipe_bot_2_x, _pipe_bot_2_y);
}

function _on_update() {
    if ((!alive)) {
        return;
    }
    vy = (vy + 2);
    _bird_y = (_bird_y + vy);
    Engine.move("bird", _bird_x, _bird_y);
    if ((_bird_y < 0)) {
        _bird_y = 0;
        Engine.move("bird", _bird_x, _bird_y);
        vy = 0;
    }
    if ((_bird_y >= 166)) {
        _bird_y = 166;
        Engine.move("bird", _bird_x, _bird_y);
        alive = false;
        Engine.setText("gameover", "GAME OVER - click to restart");
        return;
    }
    pipe_x1 = (pipe_x1 - 5);
    _pipe_top_1_x = pipe_x1;
    Engine.move("pipe_top_1", _pipe_top_1_x, _pipe_top_1_y);
    _pipe_bot_1_x = pipe_x1;
    Engine.move("pipe_bot_1", _pipe_bot_1_x, _pipe_bot_1_y);
    pipe_x2 = (pipe_x2 - 5);
    _pipe_top_2_x = pipe_x2;
    Engine.move("pipe_top_2", _pipe_top_2_x, _pipe_top_2_y);
    _pipe_bot_2_x = pipe_x2;
    Engine.move("pipe_bot_2", _pipe_bot_2_x, _pipe_bot_2_y);
    if ((pipe_x1 < -40)) {
        pipe_x1 = Engine.random(500, 750);
        gap_top1 = Engine.random(35, 115);
        gap_sz1 = Engine.random(65, 95);
        _pipe_top_1_x = pipe_x1;
        Engine.move("pipe_top_1", _pipe_top_1_x, _pipe_top_1_y);
        _pipe_bot_1_x = pipe_x1;
        Engine.move("pipe_bot_1", _pipe_bot_1_x, _pipe_bot_1_y);
        _pipe_top_1_y = (gap_top1 - 170);
        Engine.move("pipe_top_1", _pipe_top_1_x, _pipe_top_1_y);
        _pipe_bot_1_y = (gap_top1 + gap_sz1);
        Engine.move("pipe_bot_1", _pipe_bot_1_x, _pipe_bot_1_y);
        scored1 = false;
    }
    if ((pipe_x2 < -40)) {
        pipe_x2 = Engine.random(500, 750);
        gap_top2 = Engine.random(35, 115);
        gap_sz2 = Engine.random(65, 95);
        _pipe_top_2_x = pipe_x2;
        Engine.move("pipe_top_2", _pipe_top_2_x, _pipe_top_2_y);
        _pipe_bot_2_x = pipe_x2;
        Engine.move("pipe_bot_2", _pipe_bot_2_x, _pipe_bot_2_y);
        _pipe_top_2_y = (gap_top2 - 170);
        Engine.move("pipe_top_2", _pipe_top_2_x, _pipe_top_2_y);
        _pipe_bot_2_y = (gap_top2 + gap_sz2);
        Engine.move("pipe_bot_2", _pipe_bot_2_x, _pipe_bot_2_y);
        scored2 = false;
    }
    if (((!scored1) && (pipe_x1 < 65))) {
        points = (points + 1);
        Engine.setText("score", points);
        scored1 = true;
    }
    if (((!scored2) && (pipe_x2 < 65))) {
        points = (points + 1);
        Engine.setText("score", points);
        scored2 = true;
    }
    if (((((_bird_x + 4 < (_pipe_top_1_x + 40 - 6) && _pipe_top_1_x + 6 < (_bird_x + 24 - 4) && _bird_y < (_pipe_top_1_y + 170) && _pipe_top_1_y < (_bird_y + 24)) || (_bird_x + 4 < (_pipe_bot_1_x + 40 - 6) && _pipe_bot_1_x + 6 < (_bird_x + 24 - 4) && _bird_y < (_pipe_bot_1_y + 150) && _pipe_bot_1_y < (_bird_y + 24))) || (_bird_x + 4 < (_pipe_top_2_x + 40 - 6) && _pipe_top_2_x + 6 < (_bird_x + 24 - 4) && _bird_y < (_pipe_top_2_y + 170) && _pipe_top_2_y < (_bird_y + 24))) || (_bird_x + 4 < (_pipe_bot_2_x + 40 - 6) && _pipe_bot_2_x + 6 < (_bird_x + 24 - 4) && _bird_y < (_pipe_bot_2_y + 150) && _pipe_bot_2_y < (_bird_y + 24)))) {
        alive = false;
        Engine.setText("gameover", "GAME OVER - click to restart");
    }
}

function _on_click() {
    if ((!alive)) {
        _on_restart();
        return;
    }
    vy = -12;
}

function _on_restart() {
    alive = true;
    vy = 0;
    points = 0;
    _bird_y = 85;
    Engine.move("bird", _bird_x, _bird_y);
    pipe_x1 = 450;
    pipe_x2 = 725;
    gap_top1 = 80;
    gap_top2 = 55;
    gap_sz1 = 80;
    gap_sz2 = 80;
    _pipe_top_1_x = pipe_x1;
    Engine.move("pipe_top_1", _pipe_top_1_x, _pipe_top_1_y);
    _pipe_bot_1_x = pipe_x1;
    Engine.move("pipe_bot_1", _pipe_bot_1_x, _pipe_bot_1_y);
    _pipe_top_2_x = pipe_x2;
    Engine.move("pipe_top_2", _pipe_top_2_x, _pipe_top_2_y);
    _pipe_bot_2_x = pipe_x2;
    Engine.move("pipe_bot_2", _pipe_bot_2_x, _pipe_bot_2_y);
    _pipe_top_1_y = (gap_top1 - 170);
    Engine.move("pipe_top_1", _pipe_top_1_x, _pipe_top_1_y);
    _pipe_bot_1_y = (gap_top1 + gap_sz1);
    Engine.move("pipe_bot_1", _pipe_bot_1_x, _pipe_bot_1_y);
    _pipe_top_2_y = (gap_top2 - 170);
    Engine.move("pipe_top_2", _pipe_top_2_x, _pipe_top_2_y);
    _pipe_bot_2_y = (gap_top2 + gap_sz2);
    Engine.move("pipe_bot_2", _pipe_bot_2_x, _pipe_bot_2_y);
    scored1 = false;
    scored2 = false;
    Engine.setText("gameover", "");
}

Engine.onInput(function () {
    if (typeof _on_click === 'function') { _on_click(); }
});

Engine.start(_on_update, 10);

_on_start();
}
